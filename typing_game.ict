  - type: template
    baseClass: Text
    name: TerminalBox
    depth: 0
    texture: -1
    playAnimationOnStart: false
    loopAnimation: true
    animationFPS: 30
    visible: true
    events:
      - eventKey: OnStep
        lib: core
        code: |-
          let isBlinking = Math.floor(Date.now() / 500) % 2 === 0;

          let cursor = isBlinking ? "_" : " ";

          this.myText.text = ">   " + window.gameState.currentInput + cursor;
        arguments: {}
      - eventKey: OnCreate
        code: >-
          this.x = camera.width / 2;

          this.y = camera.height / 2;


          let boxWidth = camera.width * 0.5;

          let boxHeight = 65;


          this.bgShape = new PIXI.Graphics();

          this.bgShape.beginFill(0x22223b, 0.95);

          this.bgShape.drawRoundedRect(-boxWidth / 2, -boxHeight / 2, boxWidth,
          boxHeight, 15);

          this.bgShape.endFill();


          this.addChild(this.bgShape); 


          this.myText = new PIXI.Text("", styles.get('TerminalStyle'));


          this.myText.anchor.set(0, 0.5);

          this.myText.x = -boxWidth / 2 + 20;


          this.addChild(this.myText);
        arguments: {}
        lib: core
    extends:
      cgroup: ''
      'editor:myCollidingCGroups': []
